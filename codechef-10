#include <iostream>
#include <vector>

using namespace std;

int main() {
    int t;
    cin >> t;

    while (t--) {
        int n, x;
        cin >> n >> x;

        vector<int> a;
        if (n % 2 != 0) {
            a.push_back(x);
            n--;
        }

        for (int i = 1; i <= n / 2; ++i) {
            a.push_back(x - i);
            a.push_back(x + i);
        }

        for (int i = 0; i < a.size(); ++i) {
            cout << a[i] << (i == a.size() - 1 ? "" : " ");
        }
        cout << endl;
    }

    return 0;
}
